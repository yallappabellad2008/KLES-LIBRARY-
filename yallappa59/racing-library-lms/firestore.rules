rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Book validation
    function isValidBook(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.author is string && data.author.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.stock is number && data.stock >= 0 &&
             data.status in ['Active', 'Maintenance', 'Archived'];
    }

    match /books/{bookId} {
      // Students (Users) can only read
      allow read: if true; 
      
      // Employees can manage books
      // In a real app, we would check for request.auth.token.role == 'employee'
      // For this demo, we allow write if the user is signed in
      allow create: if request.auth != null && isValidBook(request.resource.data);
      allow update: if request.auth != null && isValidBook(request.resource.data);
      allow delete: if request.auth != null;
    }
  }
}
